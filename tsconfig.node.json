{
  "include": ["electron.vite.config.ts", "src/main/**/*", "src/preload/**/*"],
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "out",
    "types": ["node"]
  }
}
